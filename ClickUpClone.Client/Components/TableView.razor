@using ClickUpClone.Shared.Models
@inject HttpClient Http

<div class="view-wrapper">
    <div class="table-view-container">
        @if (!GetSortedTasks().Any())
        {
            <div class="table-view-empty">Немає завдань. Створіть завдання, щоб побачити його в таблиці!</div>
        }
        else
        {
            var sortedTasks = GetSortedTasks();
            <table class="grid-table">
                <thead>
                    <tr>
                        <th class="col-checkbox">
                            <input type="checkbox" checked="@IsAllTasksSelected(sortedTasks)" @onchange="(e) => ToggleSelectAll(e, sortedTasks)" />
                        </th>
                        <th class="sortable" @onclick='() => SortByColumn("Title")'>
                            Назва @((sortBy == "Title") ? (isAscending ? " ▲" : " ▼") : "")
                        </th>
                        <th class="sortable" @onclick='() => SortByColumn("Status")'>
                            Статус @((sortBy == "Status") ? (isAscending ? " ▲" : " ▼") : "")
                        </th>
                        <th>Виконавець</th>
                        <th class="sortable" @onclick='() => SortByColumn("Priority")'>
                            Пріоритет @((sortBy == "Priority") ? (isAscending ? " ▲" : " ▼") : "")
                        </th>
                        <th class="sortable" @onclick='() => SortByColumn("DueDate")'>
                            Кінцевий термін @((sortBy == "DueDate") ? (isAscending ? " ▲" : " ▼") : "")
                        </th>
                        <th>Теги</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in sortedTasks)
                    {
                        @RenderTaskRowRecursive(task, 0)
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Floating Bulk Actions Toolbar -->
    @if (selectedTaskIds.Any())
    {
        <div class="floating-bulk-bar">
            <div class="bulk-info">
                <span>Обрано: <strong>@selectedTaskIds.Count</strong></span>
            </div>
            <div class="bulk-actions">
                <select class="form-input bulk-status-select" @onchange="BulkUpdateStatus">
                    <option value="">Змінити статус...</option>
                    <option value="@TaskCompletionStatus.ToDo">To Do</option>
                    <option value="@TaskCompletionStatus.ReadyForDevelopment">Ready for Dev</option>
                    <option value="@TaskCompletionStatus.InProgress">In Progress</option>
                    <option value="@TaskCompletionStatus.InReview">In Review</option>
                    <option value="@TaskCompletionStatus.ReadyForTesting">Ready for Test</option>
                    <option value="@TaskCompletionStatus.InTesting">In Testing</option>
                    <option value="@TaskCompletionStatus.Tested">Tested</option>
                    <option value="@TaskCompletionStatus.Done">Done</option>
                </select>
                <button class="btn btn-danger" @onclick="BulkDelete">Видалити</button>
                <button class="btn btn-secondary" @onclick="ClearSelection">Скасувати</button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public HierarchyNode? ActiveNode { get; set; }
    [Parameter] public List<HierarchyNode> AllNodes { get; set; } = new();
    [Parameter] public List<TaskItem> AllTasks { get; set; } = new();
    [Parameter] public string SearchQuery { get; set; } = "";
    [Parameter] public string TaskTypeFilter { get; set; } = "all";
    [Parameter] public EventCallback<TaskItem> OnEditTask { get; set; }
    [Parameter] public EventCallback<TaskCompletionStatus> OnAddTask { get; set; }
    [Parameter] public EventCallback OnRefreshData { get; set; }

    private string sortBy = "DueDate";
    private bool isAscending = true;
    private Dictionary<Guid, bool> expandedTasks = new();
    private HashSet<Guid> selectedTaskIds = new();

    RenderFragment RenderTaskRowRecursive(TaskItem task, int depth) => @<text>
        @{
            var subtasks = (TaskTypeFilter == "subtask" || TaskTypeFilter == "all" || !string.IsNullOrWhiteSpace(SearchQuery))
                ? new List<TaskItem>()
                : AllTasks.Where(t => t.ParentTaskId == task.Id).ToList();
            var isExpanded = expandedTasks.GetValueOrDefault(task.Id, false);
        }
        <tr class="grid-row @(task.ParentTaskId != null ? "sub-task-row" : "main-task-row")" @onclick="() => EditTask(task)">
            <td class="col-checkbox" @onclick:stopPropagation>
                <input type="checkbox" checked="@selectedTaskIds.Contains(task.Id)" @onchange="() => ToggleTaskSelection(task.Id)" />
            </td>
            <td style="padding-left: @(12 + depth * 20)px;">
                <div class="title-cell">
                    @if (subtasks.Any())
                    {
                        <button class="subtask-toggle-btn" @onclick:stopPropagation @onclick="() => ToggleTaskExpansion(task.Id)">
                            <Icon Name="@(isExpanded ? "chevron-down" : "chevron-right")" />
                        </button>
                    }
                    else if (task.ParentTaskId != null)
                    {
                        <Icon Name="subtask" Class="subtask-indent-icon" />
                    }
                    else
                    {
                        <span class="subtask-spacer"></span>
                    }
                    <span class="task-title-text">
                        @if (!string.IsNullOrEmpty(task.TaskSeqId))
                        {
                            <span class="task-seq-id" style="color: var(--text-muted); font-weight: 500; margin-right: 6px;">@task.TaskSeqId</span>
                        }
                        @task.Title
                    </span>
                    @if (subtasks.Any())
                    {
                        <span class="subtask-count-badge" title="Кількість підзавдань">
                            <Icon Name="subtask" /> @subtasks.Count
                        </span>
                    }
                </div>
            </td>
            <td>
                <span class="subtask-status-badge @task.Status.ToString().ToLower()">
                    @GetStatusDisplayName(task.Status)
                </span>
            </td>
            <td @onclick:stopPropagation>
                @if (!string.IsNullOrEmpty(task.Assignee))
                {
                    <div class="assignee-avatar @GetAssigneeClass(task.Assignee)" title="@task.Assignee">
                        @GetInitials(task.Assignee)
                    </div>
                }
                else
                {
                    <span style="color: var(--text-muted);">—</span>
                }
            </td>
            <td>
                <span class="priority-badge @task.Priority.ToString()">@GetPriorityDisplayName(task.Priority)</span>
            </td>
            <td>
                @if (task.DueDate.HasValue)
                {
                    var isOverdue = task.DueDate.Value.Date < DateTime.Today && task.Status != TaskCompletionStatus.Done;
                    <span class="due-date-badge @(isOverdue ? "overdue" : "")">
                        @task.DueDate.Value.ToString("dd MMM yyyy")
                    </span>
                }
                else
                {
                    <span style="color: var(--text-muted);">—</span>
                }
            </td>
            <td>
                @if (task.Tags != null && task.Tags.Any())
                {
                    <div class="task-tags">
                        @foreach (var tag in task.Tags)
                        {
                            <span class="tag-pill">@tag</span>
                        }
                    </div>
                }
                else
                {
                    <span style="color: var(--text-muted);">—</span>
                }
            </td>
        </tr>

        @if (isExpanded && subtasks.Any())
        {
            @foreach (var sub in subtasks)
            {
                @RenderTaskRowRecursive(sub, depth + 1)
            }
        }
    </text>;

    private void SortByColumn(string column)
    {
        if (sortBy == column)
        {
            isAscending = !isAscending;
        }
        else
        {
            sortBy = column;
            isAscending = true;
        }
    }

    private List<TaskItem> GetSortedTasks()
    {
        if (ActiveNode == null) return new();

        List<TaskItem> rawTasks;
        if (ActiveNode.Type == NodeType.List)
        {
            rawTasks = AllTasks.Where(t => t.ListId == ActiveNode.Id).ToList();
        }
        else
        {
            var listIds = new HashSet<Guid>();
            GetChildListIds(ActiveNode.Id, listIds);
            rawTasks = AllTasks.Where(t => listIds.Contains(t.ListId)).ToList();
        }

        // Apply task type filter:
        if (TaskTypeFilter == "main")
        {
            rawTasks = rawTasks.Where(t => t.ParentTaskId == null).ToList();
        }
        else if (TaskTypeFilter == "subtask")
        {
            rawTasks = rawTasks.Where(t => t.ParentTaskId != null).ToList();
        }
        // In "all" mode, both parent tasks and subtasks are flat at top level.

        // Apply search query:
        if (!string.IsNullOrWhiteSpace(SearchQuery))
        {
            rawTasks = rawTasks.Where(t => t.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) || 
                                           (t.TaskSeqId != null && t.TaskSeqId.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase))).ToList();
        }

        var sortedTasks = rawTasks;

        if (sortBy == "Title")
        {
            sortedTasks = isAscending ? sortedTasks.OrderBy(t => t.Title).ToList() : sortedTasks.OrderByDescending(t => t.Title).ToList();
        }
        else if (sortBy == "Priority")
        {
            sortedTasks = isAscending ? sortedTasks.OrderBy(t => t.Priority).ToList() : sortedTasks.OrderByDescending(t => t.Priority).ToList();
        }
        else if (sortBy == "DueDate")
        {
            sortedTasks = isAscending 
                ? sortedTasks.OrderBy(t => t.DueDate ?? DateTime.MaxValue).ToList() 
                : sortedTasks.OrderByDescending(t => t.DueDate ?? DateTime.MinValue).ToList();
        }
        else if (sortBy == "Status")
        {
            sortedTasks = isAscending ? sortedTasks.OrderBy(t => t.Status).ToList() : sortedTasks.OrderByDescending(t => t.Status).ToList();
        }

        return sortedTasks.ToList();
    }

    private void GetChildListIds(Guid parentId, HashSet<Guid> listIds)
    {
        var children = AllNodes.Where(n => n.ParentId == parentId).ToList();
        foreach (var child in children)
        {
            if (child.Type == NodeType.List)
            {
                listIds.Add(child.Id);
            }
            else
            {
                GetChildListIds(child.Id, listIds);
            }
        }
    }

    private void ToggleTaskExpansion(Guid taskId)
    {
        if (expandedTasks.ContainsKey(taskId))
        {
            expandedTasks[taskId] = !expandedTasks[taskId];
        }
        else
        {
            expandedTasks[taskId] = true;
        }
    }

    private async Task EditTask(TaskItem task)
    {
        await OnEditTask.InvokeAsync(task);
    }

    private bool IsAllTasksSelected(List<TaskItem> tasks)
    {
        return tasks.Any() && tasks.All(t => selectedTaskIds.Contains(t.Id));
    }

    private void ToggleSelectAll(ChangeEventArgs e, List<TaskItem> tasks)
    {
        bool isChecked = (bool)(e.Value ?? false);
        if (isChecked)
        {
            foreach (var t in tasks)
            {
                selectedTaskIds.Add(t.Id);
            }
        }
        else
        {
            foreach (var t in tasks)
            {
                selectedTaskIds.Remove(t.Id);
            }
        }
    }

    private void ToggleTaskSelection(Guid taskId)
    {
        if (selectedTaskIds.Contains(taskId))
        {
            selectedTaskIds.Remove(taskId);
        }
        else
        {
            selectedTaskIds.Add(taskId);
        }
    }

    private async Task BulkUpdateStatus(ChangeEventArgs e)
    {
        var statusStr = e.Value?.ToString();
        if (string.IsNullOrEmpty(statusStr) || !Enum.TryParse<TaskCompletionStatus>(statusStr, out var newStatus))
        {
            return;
        }
        
        foreach (var id in selectedTaskIds)
        {
            var task = AllTasks.FirstOrDefault(t => t.Id == id);
            if (task != null)
            {
                task.Status = newStatus;
                await Http.PutAsJsonAsync($"api/workspace/tasks/{task.Id}", task, JsonOptions.Default);
            }
        }
        
        selectedTaskIds.Clear();
        await OnRefreshData.InvokeAsync();
    }
    
    private async Task BulkDelete()
    {
        foreach (var id in selectedTaskIds)
        {
            await Http.DeleteAsync($"api/workspace/tasks/{id}");
        }
        
        selectedTaskIds.Clear();
        await OnRefreshData.InvokeAsync();
    }
    
    private void ClearSelection()
    {
        selectedTaskIds.Clear();
    }

    private string GetStatusDisplayName(TaskCompletionStatus status)
    {
        return status switch
        {
            TaskCompletionStatus.ToDo => "To Do",
            TaskCompletionStatus.ReadyForDevelopment => "Ready for Dev",
            TaskCompletionStatus.InProgress => "In Progress",
            TaskCompletionStatus.InReview => "In Review",
            TaskCompletionStatus.ReadyForTesting => "Ready for Test",
            TaskCompletionStatus.InTesting => "In Testing",
            TaskCompletionStatus.Tested => "Tested",
            TaskCompletionStatus.Done => "Done",
            _ => status.ToString()
        };
    }

    private string GetPriorityDisplayName(TaskPriority priority)
    {
        return priority switch
        {
            TaskPriority.Urgent => "Urgent",
            TaskPriority.High => "High",
            TaskPriority.Normal => "Normal",
            TaskPriority.Low => "Low",
            _ => priority.ToString()
        };
    }

    private string GetInitials(string? assignee)
    {
        if (string.IsNullOrWhiteSpace(assignee)) return "";
        var name = assignee.Split('(')[0].Trim();
        var parts = name.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "";
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper();
        return (parts[0][0].ToString() + parts[1][0].ToString()).ToUpper();
    }

    private string GetAssigneeClass(string? assignee)
    {
        if (string.IsNullOrWhiteSpace(assignee)) return "";
        if (assignee.Contains("Розробник") || assignee.Contains("Developer")) return "assignee-dev";
        if (assignee.Contains("Тестувальник") || assignee.Contains("QA")) return "assignee-qa";
        if (assignee.Contains("Дизайнер") || assignee.Contains("Designer")) return "assignee-designer";
        if (assignee.Contains("Manager") || assignee.Contains("Олена")) return "assignee-pm";
        return "assignee-default";
    }
}
